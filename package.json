{
  "name": "minicode",
  "version": "0.1.0",
  "description": "A minimal Claude Code-like CLI tool",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.tsx",
    "dev": "tsx watch src/index.tsx",
    "typecheck": "tsc --noEmit",
    "build": "tsx build.ts",
    "build:bundle": "esbuild src/index.tsx --bundle --platform=node --format=esm --outfile=dist/minicode.mjs --minify --external:node:* --external:assert --alias:react-devtools-core=./stubs/empty.js",
    "build:exe": "tsx build.ts --exe",
    "build:bun": "bun build --compile src/index.tsx --outfile minicode.exe"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-syntax-highlight": "^2.0.2",
    "marked": "^15.0.6",
    "marked-terminal": "^7.2.1",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-devtools-core": "^4.28.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
