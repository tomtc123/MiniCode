# MiniCode 环境变量配置
# 复制此文件为 .env 并填入你的配置

# LLM 提供商: openai, anthropic, deepseek, mock
MINICODE_PROVIDER=deepseek

# API 密钥
MINICODE_API_KEY=你的API密钥

# 模型名称（可选，有默认值）
# MINICODE_MODEL=deepseek-v4-flash

# API 基础地址（可选，有默认值）
# MINICODE_BASE_URL=https://api.deepseek.com

# 系统提示词（可选）
# MINICODE_SYSTEM_PROMPT=You are a helpful coding assistant.

# 最大 token 数（可选，默认 4096）
# MINICODE_MAX_TOKENS=4096
